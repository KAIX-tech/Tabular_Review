# Frontend (Next.js) environment. All client-exposed vars must be NEXT_PUBLIC_*.

# Browser-facing backend base URL (FastAPI). The LLM proxy + /convert live here.
NEXT_PUBLIC_API_URL=http://10.10.190.4:18002

# Optional explicit LLM proxy URL. Defaults to `${NEXT_PUBLIC_API_URL}/llm/chat/completions`.
# NEXT_PUBLIC_LLM_PROXY_URL=

# Display/default model id and client-side request timeout.
NEXT_PUBLIC_LLM_MODEL=glm-5
NEXT_PUBLIC_LLM_TIMEOUT_MS=120000
