# Environment variables for Docker Compose
# Copy this file to .env and fill in your values

# Database (PostgreSQL + pgvector). The backend assembles its async DSN from
# these discrete POSTGRES_* components (config.py), so production can point at a
# shared/managed DB by just changing POSTGRES_SERVER/PORT/credentials.
# Inside compose the backend overrides POSTGRES_SERVER=db / POSTGRES_PORT=5432;
# these values are for host access (local non-docker dev) and as the prod template.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kalex
POSTGRES_USER=kalex
POSTGRES_PASSWORD=kalex
# Host port the compose `db` service is published on (container port is always
# 5432). Defaults to 15432 to avoid clashing with a local Postgres.
POSTGRES_HOST_PORT=15432

# AI provider for embedding + generation adapters.
#   gemini  = dev (Gemini API; needs GEMINI_API_KEY)
#   onprem  = BGE-M3 embedding + vLLM generation
AI_PROVIDER=gemini
# Embedding vector dimension. MUST match the pgvector column (1024 = BGE-M3).
# The Gemini adapter forces output_dimensionality to this value (+ L2 normalize).
EMBEDDING_DIM=1024
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_LLM_MODEL=gemini-2.5-flash

# On-prem embedding (AI_PROVIDER=onprem): HF Text-Embeddings-Inference serving
# BGE-M3. Only a base URL (+ optional bearer key) is needed; the served model
# must emit EMBEDDING_DIM-length vectors. Ignored when AI_PROVIDER=gemini.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=60
# On-prem generation uses the VLLM_* settings below. Set false if the served
# model/vLLM build rejects OpenAI response_format={"type":"json_object"}.
VLLM_JSON_OBJECT_MODE=true

# Langfuse LLM-call tracing (optional). Tracing turns on only when BOTH keys are
# set. LANGFUSE_BASE_URL maps to the SDK `host` (use the EU/US cloud or self-host).
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Object storage (MinIO / S3) for original uploaded files. Inside compose the
# endpoint is `minio:9000`; for local dev against the compose MinIO use
# localhost:${MINIO_PORT}.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=kalex
MINIO_SECRET_KEY=kalexsecret
MINIO_BUCKET=kalex-documents
MINIO_SECURE=false
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend-side on-prem LLM configuration (vLLM OpenAI-compatible API)
VLLM_BASE_URL=http://10.10.190.10:15006/v1
# Leave empty or EMPTY when vLLM is not started with --api-key.
VLLM_API_KEY=EMPTY
VLLM_MODEL=glm-5
VLLM_TIMEOUT_SECONDS=120

# Frontend LLM configuration
NEXT_PUBLIC_LLM_MODEL=glm-5
NEXT_PUBLIC_LLM_TIMEOUT_MS=120000

# Mock toggles (baked into the frontend bundle at build time). "false" => real API.
# Per-domain flags fall back to the global one, so each domain switches to the real
# backend as its context lands. document_db is implemented (Phase 1).
NEXT_PUBLIC_USE_MOCKS=true
NEXT_PUBLIC_USE_MOCKS_DOCUMENT_DB=false
NEXT_PUBLIC_USE_MOCKS_CHAT=true
# document-review (문서 업로드/목록/상태) — ingestion 백엔드 연동(Phase 2)
NEXT_PUBLIC_USE_MOCKS_REVIEW=false

# Backend configuration.
# (Container runtime — PYTHONUNBUFFERED/PYTHONIOENCODING/LANG/LC_ALL — live in
# backend/Dockerfile, not here.)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:13002
# Docling models.
#  - Dev (docker-compose.yml): leave unset → Docling auto-downloads on first use.
#  - Prod (docker-compose.prod.yml, air-gapped): models are mounted read-only from
#    the host and DOCLING_ARTIFACTS_PATH is set automatically by that compose file.
#    Put the prefetched model folders on the host and point DOCLING_MODELS_HOST_PATH
#    at them (folders: docling-project--docling-layout-heron / --docling-models).
DOCLING_MODELS_HOST_PATH=./docling-models
DOCLING_OCR_ENABLED=true
DOCLING_OCR_FORCE_FULL_PAGE=false
DOCLING_OCR_LANGS=eng,kor
# Retry searchable PDFs without OCR if Tesseract stdout cannot be decoded as UTF-8.
DOCLING_OCR_FALLBACK_ON_DECODE_ERROR=true
# Use pypdfium2 to avoid UTF-8 decode failures in docling_parse on some PDFs.
DOCLING_PDF_BACKEND=pypdfium2
# Set true only when an internal TLS proxy/self-signed cert blocks Hugging Face model downloads.
DOCLING_HF_DISABLE_SSL_VERIFY=true
# Keep false unless Hugging Face downloads must use proxy variables from the environment.
DOCLING_HF_TRUST_ENV=false
# Disable hf-xet so model files use the Python Hugging Face client path where SSL bypass is applied.
HF_HUB_DISABLE_XET=1
# Used by server/download_docling_models.py when prefetching Docling artifacts.
DOCLING_MODEL_CACHE=/root/.cache/docling/models
# Optional token and browser-like user agent for server/download_docling_models.py.
HF_TOKEN=
HF_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# API URL for frontend to connect to backend (browser-facing). Baked into the
# bundle at build time via docker-compose build.args. Use the host/IP the browser
# reaches the backend at (e.g. http://localhost:18002 locally, or a LAN IP/domain).
NEXT_PUBLIC_API_URL=http://localhost:18002

# Frontend runtime environment.
NODE_ENV=production
