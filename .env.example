# Environment variables for Docker Compose.
# Copy this file to .env and fill in your values.
# Every backend var is declared in backend/app/core/config.py (single source of
# truth); anything omitted here falls back to the default in that file.

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# The backend assembles its async DSN from these discrete POSTGRES_* components,
# so production can point at a shared/managed DB by changing SERVER/PORT/creds.
# Inside compose the backend overrides POSTGRES_SERVER=db / POSTGRES_PORT=5432;
# the values here are for host access (local non-docker dev) and the prod template.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kalex
POSTGRES_USER=kalex
POSTGRES_PASSWORD=kalex
# Host port the compose `db` service is published on (container port is always
# 5432). Defaults to 15432 to avoid clashing with a local Postgres.
POSTGRES_HOST_PORT=15432

# ── LLM generation provider ──────────────────────────────────────────────────
# Both targets are OpenAI-compatible chat completions; the chat agent additionally
# requires native tool-calling on the served model.
#   onprem     = vLLM/GLM (prod default; VLLM_* below — tool-calling flags required,
#                see README `vllm serve` example)
#   openrouter = GLM via OpenRouter (dev; OPENROUTER_* below — needs an API key)
LLM_PROVIDER=onprem
# Active LLM context window (tokens). Extraction sends whole documents within this
# budget, else falls back to retrieval. Default 65000 (on-prem GLM).
LLM_CONTEXT_TOKENS=65000

# On-prem vLLM (LLM_PROVIDER=onprem).
VLLM_BASE_URL=http://10.10.190.10:15006/v1
# Leave empty or EMPTY when vLLM is not started with --api-key.
VLLM_API_KEY=EMPTY
VLLM_MODEL=glm-5
VLLM_TIMEOUT_SECONDS=120
# Set false if the served model/vLLM build rejects response_format={"type":"json_object"}.
VLLM_JSON_OBJECT_MODE=true

# OpenRouter (LLM_PROVIDER=openrouter). Fill OPENROUTER_API_KEY (sk-or-...). Pick a
# GLM the account can reach and that supports tool-calling (e.g. z-ai/glm-4.6).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-4.6

# ── Embedding (HF Text-Embeddings-Inference / BGE-M3) ────────────────────────
# Required for any ingestion/search. The served model must emit EMBEDDING_DIM-length
# vectors; EMBEDDING_DIM must match the pgvector column (1024 = BGE-M3).
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT_SECONDS=60

# ── Chat agent (Agentic Search) — optional tuning, sane defaults ─────────────
# Max tool-call rounds per question (LangGraph recursion_limit = 2×steps+1).
#CHAT_MAX_STEPS=8
# Per-tool-result token cap (results are clipped with a truncated marker).
#CHAT_TOOL_RESULT_MAX_TOKENS=4000
# Max citations per assistant message.
#CHAT_MAX_SOURCES=5
# Default top-k for the search_chunks tool.
#CHAT_SEARCH_K=8

# ── Langfuse LLM tracing (optional) ──────────────────────────────────────────
# Tracing turns on only when BOTH keys are set. LANGFUSE_BASE_URL maps to the SDK
# `host` (EU/US cloud or self-hosted).
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Object storage (MinIO / S3) for original uploaded files ──────────────────
# Inside compose the endpoint is `minio:9000`; for local non-docker dev against the
# compose MinIO use localhost:${MINIO_PORT}.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=kalex
MINIO_SECRET_KEY=kalexsecret
MINIO_BUCKET=kalex-documents
MINIO_SECURE=false
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Service hosts/ports (browser-facing) ─────────────────────────────────────
# The two addresses as the BROWSER reaches them, split host/port. Everything
# else derives from these — single source of truth:
#  - BACKEND_HOST:BACKEND_PORT   → frontend NEXT_PUBLIC_API_URL (compose wires
#    it; changing it requires a frontend image rebuild in prod) + the compose
#    port publish for the backend.
#  - FRONTEND_HOST:FRONTEND_PORT → backend CORS allow-origin (localhost dev
#    origins always allowed in addition; no CORS_ORIGINS variable) + the
#    compose port publish for the frontend.
# Prod example: BACKEND_HOST=http://10.10.190.4, FRONTEND_HOST=http://10.10.190.4
BACKEND_HOST=http://localhost
BACKEND_PORT=18002
FRONTEND_HOST=http://localhost
FRONTEND_PORT=13002

# ── Docling document conversion ──────────────────────────────────────────────
#  - Dev (docker-compose.yml): leave DOCLING_MODELS_HOST_PATH unset → Docling
#    auto-downloads models on first use.
#  - Prod (docker-compose.prod.yml, air-gapped): models are mounted read-only from
#    the host; put the prefetched folders (docling-project--docling-layout-heron /
#    --docling-models) at DOCLING_MODELS_HOST_PATH.
DOCLING_MODELS_HOST_PATH=./docling-models
DOCLING_OCR_ENABLED=true
DOCLING_OCR_FORCE_FULL_PAGE=false
DOCLING_OCR_LANGS=eng,kor
# Retry searchable PDFs without OCR if Tesseract stdout cannot be decoded as UTF-8.
DOCLING_OCR_FALLBACK_ON_DECODE_ERROR=true
# Use pypdfium2 to avoid UTF-8 decode failures in docling_parse on some PDFs.
DOCLING_PDF_BACKEND=pypdfium2
# Set true only when an internal TLS proxy/self-signed cert blocks Hugging Face downloads.
DOCLING_HF_DISABLE_SSL_VERIFY=true
# Keep false unless Hugging Face downloads must use proxy variables from the environment.
DOCLING_HF_TRUST_ENV=false
# Disable hf-xet so model files use the Python HF client path where the SSL bypass applies.
HF_HUB_DISABLE_XET=1
# Used by backend/scripts/download_docling_models.py when prefetching artifacts.
DOCLING_MODEL_CACHE=/root/.cache/docling/models
# Optional token + browser-like user agent for the prefetch script.
HF_TOKEN=
HF_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# ── Frontend (NEXT_PUBLIC_* are baked into the bundle at build time) ─────────
# The backend URL comes from BACKEND_HOST above (compose maps it to
# NEXT_PUBLIC_API_URL). Non-docker `pnpm dev` sets NEXT_PUBLIC_API_URL directly
# in frontend/.env.local instead.
NEXT_PUBLIC_LLM_MODEL=glm-5
NEXT_PUBLIC_LLM_TIMEOUT_MS=120000
# Frontend runtime environment (prod compose).
NODE_ENV=production

# Mocks are OPT-IN for offline UI development only — every context is backed by
# the real API. Uncomment to force fixture mode (non-docker `pnpm dev` workflows):
#NEXT_PUBLIC_USE_MOCKS=true
