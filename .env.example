# Copy to .env and fill in your values. Every backend var is declared in
# backend/app/core/config.py; anything omitted falls back to its default there.

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# Compose overrides SERVER=db / PORT=5432 in-network; values below are for host
# access. POSTGRES_HOST_PORT = the published host port.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kalex
POSTGRES_USER=kalex
POSTGRES_PASSWORD=kalex
POSTGRES_HOST_PORT=15432

# ── Service hosts/ports (browser-facing) ─────────────────────────────────────
# Single source of truth: BACKEND_* → NEXT_PUBLIC_API_URL + backend port publish,
# FRONTEND_* → backend CORS + frontend port publish.
# Prod example: BACKEND_HOST=http://10.10.190.4, FRONTEND_HOST=http://10.10.190.4
BACKEND_HOST=http://localhost
BACKEND_PORT=18002
FRONTEND_HOST=http://localhost
FRONTEND_PORT=13002

# ── LLM generation provider (onprem = vLLM/GLM, openrouter = dev GLM) ────────
# The served model must support native tool-calling (chat agent).
LLM_PROVIDER=onprem
LLM_CONTEXT_TOKENS=65000

# On-prem vLLM (LLM_PROVIDER=onprem). VLLM_API_KEY=EMPTY when vLLM has no --api-key.
VLLM_BASE_URL=http://10.10.190.10:15006/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=glm-5
VLLM_TIMEOUT_SECONDS=120
VLLM_JSON_OBJECT_MODE=true

# OpenRouter (LLM_PROVIDER=openrouter).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-4.6

# ── Embedding (HF TEI / BGE-M3) — required for ingestion/search ──────────────
# EMBEDDING_DIM must match the pgvector column (1024 = BGE-M3).
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT_SECONDS=60

# ── Chat agent tuning (optional; defaults are fine) ──────────────────────────
#CHAT_MAX_STEPS=8
#CHAT_TOOL_RESULT_MAX_TOKENS=4000
#CHAT_MAX_SOURCES=5
#CHAT_SEARCH_K=8

# ── Langfuse LLM tracing (optional; on only when BOTH keys are set) ──────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Object storage (MinIO / S3) for original uploaded files ──────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=kalex
MINIO_SECRET_KEY=kalexsecret
MINIO_BUCKET=kalex-documents
MINIO_SECURE=false
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Docling document conversion ──────────────────────────────────────────────
# DOCLING_MODELS_HOST_PATH: prod (air-gapped) mounts prefetched models from here;
# leave unset in dev to auto-download.
DOCLING_MODELS_HOST_PATH=./docling-models
DOCLING_OCR_ENABLED=true
DOCLING_OCR_FORCE_FULL_PAGE=false
DOCLING_OCR_LANGS=eng,kor
DOCLING_OCR_FALLBACK_ON_DECODE_ERROR=true
DOCLING_PDF_BACKEND=pypdfium2
DOCLING_HF_DISABLE_SSL_VERIFY=true
DOCLING_HF_TRUST_ENV=false
HF_HUB_DISABLE_XET=1
DOCLING_MODEL_CACHE=/root/.cache/docling/models
HF_TOKEN=
HF_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_LLM_MODEL=glm-5
NEXT_PUBLIC_LLM_TIMEOUT_MS=120000
NODE_ENV=production
# Mocks are opt-in for offline UI work only:
#NEXT_PUBLIC_USE_MOCKS=true
